[Unit]
Description=Orion Dashboard V20.9
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/orion/dashboard
EnvironmentFile=/home/ubuntu/orion/.env
ExecStart=/home/ubuntu/orion/venv/bin/gunicorn -w 2 -b 127.0.0.1:5000 app:app
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
